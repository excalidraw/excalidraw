{
  "private": true,
  "name": "excalidraw-monorepo",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "excalidraw-app",
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@babel/preset-env": "7.26.9",
    "@excalidraw/eslint-config": "1.0.3",
    "@excalidraw/prettier-config": "1.0.2",
    "@sonar/scan": "4.3.6",
    "@types/chai": "4.3.0",
    "@types/jest": "27.4.0",
    "@types/lodash.throttle": "4.1.7",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/socket.io-client": "3.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "3.1.0",
    "@vitest/coverage-v8": "3.0.7",
    "@vitest/ui": "2.0.5",
    "chai": "4.3.6",
    "depcheck": "1.4.7",
    "dependency-cruiser": "^16.0.0",
    "dotenv": "16.0.1",
    "eslint-config-prettier": "8.5.0",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "3.3.1",
    "eslint-plugin-sonarjs": "0.23.0",
    "http-server": "14.1.1",
    "husky": "7.0.4",
    "jsdom": "22.1.0",
    "knip": "6.15.0",
    "lint-staged": "12.3.7",
    "madge": "8.0.0",
    "nodemon": "3.1.14",
    "oxlint": "^0.16.0",
    "playwright": "1.51.0",
    "pepjs": "0.5.3",
    "prettier": "2.6.2",
    "rewire": "6.0.0",
    "rimraf": "^5.0.0",
    "sharp": "0.34.2",
    "typescript": "5.9.3",
    "vite": "5.0.12",
    "vite-plugin-checker": "0.7.2",
    "vite-plugin-ejs": "1.7.0",
    "vite-plugin-pwa": "0.21.1",
    "vite-plugin-svgr": "4.2.0",
    "vitest": "3.0.6",
    "vitest-canvas-mock": "0.3.3",
    "wrangler": "4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": ".",
  "prettier": "@excalidraw/prettier-config",
  "scripts": {
    "build-node": "node ./scripts/build-node.js",
    "build:app:docker": "yarn --cwd ./excalidraw-app build:app:docker",
    "build:pages": "yarn --cwd ./excalidraw-app build:pages",
    "deploy:pages": "yarn build:pages && wrangler pages deploy ./excalidraw-app/build",
    "build:app": "yarn --cwd ./excalidraw-app build:app",
    "build:common": "yarn --cwd ./packages/common build:esm",
    "build:element": "yarn --cwd ./packages/element build:esm",
    "build:excalidraw": "yarn --cwd ./packages/excalidraw build:esm",
    "build:math": "yarn --cwd ./packages/math build:esm",
    "build:packages": "yarn build:common && yarn build:math && yarn build:element && yarn build:excalidraw",
    "build:version": "yarn --cwd ./excalidraw-app build:version",
    "build": "yarn --cwd ./excalidraw-app build",
    "build:preview": "yarn --cwd ./excalidraw-app build:preview",
    "seed:terraform-presets": "node excalidraw-app/dev/seedTerraformImportPresets.mjs",
    "hydrate:terraform-preset": "node excalidraw-app/dev/hydrateTerraformImportPreset.mjs",
    "precompute:terraform-layout-cache": "node scripts/terraform/precompute-terraform-layout-cache.mjs",
    "purge:terraform-layout-cache": "node scripts/terraform/purge-terraform-layout-cache.mjs",
    "purge:terraform-layout-cache:preview": "node scripts/terraform/purge-terraform-layout-cache.mjs --preview",
    "export:brand-assets": "node scripts/export-brand-assets.mjs",
    "benchmark:landing": "node scripts/benchmark-landing.mjs",
    "benchmark:landing:preview": "node scripts/benchmark-landing.mjs --url https://terraform-feature.ainur-chb.pages.dev --label preview",
    "export:terraform-presets-test-db": "node excalidraw-app/dev/exportTerraformPresetsTestDb.mjs",
    "export:terraform-presets-d1": "node excalidraw-app/dev/exportTerraformPresetsToD1.mjs",
    "push:terraform-presets-d1:prod": "yarn export:terraform-presets-d1 && wrangler d1 execute tfdraw-presets --remote --file=./functions/generated/presets-data.sql",
    "push:terraform-presets-d1:preview": "yarn export:terraform-presets-d1 && wrangler d1 execute tfdraw-presets-preview --remote --file=./functions/generated/presets-data.sql",
    "push:terraform-presets-d1": "yarn export:terraform-presets-d1 && yarn push:terraform-presets-d1:prod && yarn push:terraform-presets-d1:preview",
    "verify:terraform-presets-test-db": "node excalidraw-app/dev/verifyTerraformPresetsTestDb.mjs",
    "start": "yarn --cwd ./excalidraw-app start",
    "start:production": "yarn --cwd ./excalidraw-app start:production",
    "start:example": "yarn build:packages && yarn --cwd ./examples/with-script-in-browser start",
    "test:all": "yarn test:typecheck && yarn test:code && yarn test:other && yarn test:app --watch=false",
    "test:commit": "yarn test:typecheck && yarn test:fast",
    "test:fast": "VITEST_FAST=1 vitest run --watch=false",
    "test:slow": "VITEST_SLOW_ONLY=1 vitest run --watch=false",
    "test:prepush": "yarn test:typecheck && yarn test:code && yarn test:other && yarn lint:arch && yarn lint:oxlint && yarn knip && yarn depcheck && yarn test:coverage && yarn workspace @excalidraw/excalidraw run build:esm && yarn workspace @excalidraw/excalidraw run check:size",
    "test:prepush:fast": "yarn test:typecheck && yarn test:code && yarn test:other && yarn lint:arch && yarn lint:oxlint && yarn knip && yarn depcheck && yarn test:fast && yarn workspace @excalidraw/excalidraw run build:esm && yarn workspace @excalidraw/excalidraw run check:size",
    "test:app": "vitest",
    "test:code": "eslint --max-warnings=0 --ext .js,.ts,.tsx .",
    "test:other": "yarn prettier --list-different",
    "test:typecheck": "tsc",
    "test:update": "yarn test:app --update --watch=false",
    "test": "yarn test:app",
    "test:coverage": "VITEST_COVERAGE=1 vitest run --coverage",
    "test:coverage:watch": "vitest --coverage --watch",
    "test:ui": "yarn test --ui --coverage.enabled=true",
    "fix:code": "yarn test:code --fix",
    "fix:other": "yarn prettier --write",
    "fix": "yarn fix:other && yarn fix:code",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "depcheck": "depcheck --skip-missing",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs packages/excalidraw/components",
    "lint:oxlint": "bash scripts/lint-oxlint.sh",
    "lint:quality": "yarn lint:arch && yarn lint:oxlint",
    "sonar:up": "docker compose -f docker-compose.sonarqube.yml up -d",
    "sonar:down": "docker compose -f docker-compose.sonarqube.yml down",
    "sonar:scan": "yarn test:coverage && npx @sonar/scan",
    "analyze:deps": "madge --circular --extensions ts,tsx packages/excalidraw/components/terraformLayoutCore.ts",
    "health": "yarn fix && yarn test:typecheck && yarn test:code && yarn lint:arch && yarn knip && yarn depcheck",
    "fmt:terraform": "bash scripts/fmt-terraform.sh",
    "locales-coverage": "node scripts/build-locales-coverage.js",
    "locales-coverage:description": "node scripts/locales-coverage-description.js",
    "prepare": "husky install",
    "prettier": "prettier \"**/*.{css,scss,json,md,html,yml}\" --ignore-path=.eslintignore",
    "release": "node scripts/release.js",
    "release:test": "node scripts/release.js --tag=test",
    "release:next": "node scripts/release.js --tag=next",
    "release:latest": "node scripts/release.js --tag=latest",
    "bundle:whiteboard": "node scripts/bundle-whiteboard.js",
    "bundle:whiteboard:archive": "node scripts/bundle-whiteboard.js --skip-build",
    "rm:build": "rimraf --glob excalidraw-app/build excalidraw-app/dist excalidraw-app/dev-dist packages/*/dist packages/*/build examples/*/build examples/*/dist",
    "rm:node_modules": "rimraf --glob node_modules excalidraw-app/node_modules packages/*/node_modules",
    "clean-install": "yarn rm:node_modules && yarn install"
  },
  "resolutions": {
    "strip-ansi": "6.0.1"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
