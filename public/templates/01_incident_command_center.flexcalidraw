    {
      "id": "py8TIa_fEu3Ih7TFBaWMK",
      "type": "text",
      "x": 427.2214073158825,
      "y": -10.887335080817309,
      "width": 432.7563853096004,
      "height": 350.3265976315813,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "5cTWeAhr1OGtSQLwHqrQl",
      "index": "aW",
      "roundness": null,
      "seed": 1254288287,
      "version": 5902,
      "versionNonce": 953085154,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1771550737187,
      "link": null,
      "locked": false,
      "text": "The data reveals a comparative analysis of error\nrates across different regions, measured in basis\npoints (bps). North America exhibits the highest\nerror rate at 35,210 bps, indicating a significant level\nof errors compared to other regions. APAC follows\nwith an error rate of 30,842 bps, showing a slightly\nlower but still substantial error occurrence. Europe\nand LATAM have relatively lower error rates, with\nEurope at 28,835 bps and LATAM at 26,965 bps.\nThis distribution suggests that North America faces\nthe most challenges in terms of error rates, while\nLATAM experiences the least. The differences in\nerror rates could point to varying operational\nefficiencies or challenges specific to each region.\nUnderstanding these discrepancies can be crucial for\naddressing regional issues and improving overall\nperformance.",
      "fontSize": 16.485957535603823,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The data reveals a comparative analysis of error rates across different regions, measured in basis points (bps). North America exhibits the highest error rate at 35,210 bps, indicating a significant level of errors compared to other regions. APAC follows with an error rate of 30,842 bps, showing a slightly lower but still substantial error occurrence. Europe and LATAM have relatively lower error rates, with Europe at 28,835 bps and LATAM at 26,965 bps. This distribution suggests that North America faces the most challenges in terms of error rates, while LATAM experiences the least. The differences in error rates could point to varying operational efficiencies or challenges specific to each region. Understanding these discrepancies can be crucial for addressing regional issues and improving overall performance.",
      "autoResize": false,
      "lineHeight": 1.25
    },
