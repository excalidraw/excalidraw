    {
      "id": "hoYsBB0R0xGbkEZPWDLh6",
      "type": "text",
      "x": -8.913707615015937,
      "y": -96.91568951818425,
      "width": 535.7936199071243,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "8T15Qk7XK2Psmy0T9z06N",
      "index": "aa",
      "roundness": null,
      "seed": 547720894,
      "version": 1075,
      "versionNonce": 820976355,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771551299022,
      "link": null,
      "locked": false,
      "text": "The data reveals a fluctuating pattern in p99 latency over time,\nwith notable peaks and troughs. In early 2026, latency showed a\nsignificant increase, peaking at **346.2 ms** on February 7, before\ndeclining to **282.99 ms** by February 16. This period was marked\nby volatility, with latency frequently exceeding **300 ms**. In\ncontrast, the latter part of 2025 exhibited a more stable trend,\nwith latency generally ranging between **200 ms** and **300 ms**,\nexcept for occasional spikes, such as **359.55 ms** on December 9.\nThe data from 2024 shows a similar pattern, with latency often\nhovering around **250 ms** but occasionally dropping below **200\nms**, indicating periods of improved performance. Overall, the data\nsuggests a recurring pattern of latency spikes followed by periods\nof stabilization, highlighting the need for consistent monitoring to\nmanage performance effectively.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The data reveals a fluctuating pattern in p99 latency over time, with notable peaks and troughs. In early 2026, latency showed a significant increase, peaking at **346.2 ms** on February 7, before declining to **282.99 ms** by February 16. This period was marked by volatility, with latency frequently exceeding **300 ms**. In contrast, the latter part of 2025 exhibited a more stable trend, with latency generally ranging between **200 ms** and **300 ms**, except for occasional spikes, such as **359.55 ms** on December 9. The data from 2024 shows a similar pattern, with latency often hovering around **250 ms** but occasionally dropping below **200 ms**, indicating periods of improved performance. Overall, the data suggests a recurring pattern of latency spikes followed by periods of stabilization, highlighting the need for consistent monitoring to manage performance effectively.",
      "autoResize": false,
      "lineHeight": 1.25
    },
