    {
      "id": "lipgTEFqiGohjMi1E4Pzw",
      "type": "text",
      "x": 583.05478133932,
      "y": -96.67853593469903,
      "width": 432.7563853096004,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "O18sRD0e2DhOIf6aEpV1Z",
      "index": "ac",
      "roundness": null,
      "seed": 1666273982,
      "version": 1353,
      "versionNonce": 1385823779,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771551299022,
      "link": null,
      "locked": false,
      "text": "The data reveals a comparison of error rates across\ndifferent regions, measured in basis points (bps). North\nAmerica leads with the highest error rate at 391,474\nbps, indicating a significant level of errors compared to\nother regions. APAC follows closely with an error rate\nof 379,096 bps, suggesting a similar level of challenges\nin maintaining accuracy. LATAM and Europe show\nslightly lower error rates, at 359,684 bps and 352,853\nbps respectively, indicating relatively better\nperformance in these regions. The differences in error\nrates highlight potential areas for improvement,\nparticularly in North America and APAC, where the\nrates are notably higher. This data could be crucial for\nidentifying regional performance issues and prioritizing\nefforts to reduce error rates.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The data reveals a comparison of error rates across different regions, measured in basis points (bps). North America leads with the highest error rate at 391,474 bps, indicating a significant level of errors compared to other regions. APAC follows closely with an error rate of 379,096 bps, suggesting a similar level of challenges in maintaining accuracy. LATAM and Europe show slightly lower error rates, at 359,684 bps and 352,853 bps respectively, indicating relatively better performance in these regions. The differences in error rates highlight potential areas for improvement, particularly in North America and APAC, where the rates are notably higher. This data could be crucial for identifying regional performance issues and prioritizing efforts to reduce error rates.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
