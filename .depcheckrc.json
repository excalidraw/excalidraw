{
  "ignores": [
    "@types/*",
    "eslint-*",
    "@excalidraw/*",
    "@babel/*",
    "@vitejs/*",
    "@vitest/*",
    "vite-plugin-*",
    "vitest-canvas-mock",
    "husky",
    "lint-staged",
    "prettier",
    "typescript",
    "rimraf",
    "knip",
    "depcheck",
    "madge",
    "react",
    "react-dom",
    "chai",
    "dotenv",
    "http-server",
    "nodemon",
    "pepjs",
    "vite"
