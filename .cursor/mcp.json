{
  "mcpServers": {
    "chrome-devtools-custom": {
      "command": "/bin/zsh",
      "args": ["-lc", "export PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin; /opt/homebrew/bin/npx -y chrome-devtools-mcp@latest"],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "gcloud": {
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "export PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin; /opt/homebrew/bin/npx -y @google-cloud/gcloud-mcp"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  }
}
