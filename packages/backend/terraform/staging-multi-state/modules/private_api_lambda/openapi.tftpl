openapi: 3.0.1
info:
  title: ${api_name}
  version: "1.0"
paths:
  /invoke:
    post:
      operationId: invoke${operation_suffix}
      x-amazon-apigateway-integration:
        type: aws_proxy
        httpMethod: POST
        uri: ${lambda_invoke_uri}
      responses:
        "200":
          description: OK
components: {}
