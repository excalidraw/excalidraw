# Account A (us-east-1 / us-west-2)
aws_profile                  = "admin"
aws_account_id               = "111111111111"
terraform_deploy_role_arn    = "arn:aws:iam::111111111111:role/TerraformDeploy"
environment                  = "production"

# Account B (eu-west-1 / eu-central-1) — use in 02/03/20/21/22 stacks
# aws_profile               = "admin-account-b"
# aws_account_id              = "222222222222"
# terraform_deploy_role_arn   = "arn:aws:iam::222222222222:role/TerraformDeploy"

# Cross-account consumer role (account B API stacks 20–22)
# consumer_lambda_role_arn  = "arn:aws:iam::111111111111:role/production-geo-fanout-consumer"

# Optional scheduled ingress
# enable_schedule           = true
# schedule_expression       = "rate(5 minutes)"
