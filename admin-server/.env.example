ADMIN_PORT=3003
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Admin uses the same MySQL/Redis env names as collab-server.
# Prefer putting these in ../collab-server/.env so admin and cob share them.
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=
MYSQL_DATABASE=shangban
REDIS_URL=redis://your-redis-host:6379
