# Copy to .env and fill in your key (never commit .env):
#   cp .env.example .env
#
# Existing shell env vars take precedence over .env.

OPENAI_API_KEY=your-key-here

# Named embed profiles (see: uv run repo-rag embed profiles)
# RAG_EMBED_PROFILE=openai-large
# RAG_EMBED_PROFILE=mlx-qwen4b
# REPO_RAG_EMBED_PROFILE=openai-large

# Gemini (optional: rag-common[gemini])
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Legacy embedding backend: auto (OpenAI if key valid, else local), openai, local, or gemini
# RAG_EMBED_BACKEND=auto

# Optional overrides:
# REPO_RAG_EMBED_BACKEND=auto
# REPO_RAG_EMBED_MODEL=text-embedding-3-large
# REPO_RAG_EMBED_DIMS=3072
# RAG_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
# REPO_RAG_LOG=1
# REPO_RAG_LOG_LEVEL=INFO
# REPO_RAG_WORKERS=12
