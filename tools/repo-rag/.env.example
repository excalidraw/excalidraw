# Copy to .env for local overrides (never commit .env):
#   cp .env.example .env
#
# Existing shell env vars take precedence over .env.

# M4 Pro / Apple Silicon local default: Qwen3-Embedding-4B, 4-bit MLX, 1024 dims.
# No OPENAI_API_KEY, CUDA box, or remote GPU settings are required.
RAG_EMBED_PROFILE=mlx-qwen4b
# REPO_RAG_EMBED_PROFILE=mlx-qwen4b

# Higher-fidelity local benchmark profile: Qwen3-Embedding-4B native 2560 dims.
# RAG_EMBED_PROFILE=qwen3-code

# Optional GPU dense re-embed (Ubuntu 3060 Ti; shared scripts in tools/rag-common/scripts/)
# Build gemini-2 once on Mac/Vertex, then reembed on the CUDA box.
# RAG_EMBED_PROFILE=gemini-2
# RAG_GPU_SSH=desktop
# RAG_GPU_REMOTE_ROOT=excalidraw-tf
# RAG_GPU_TOOL=tools/repo-rag
# RAG_GPU_SOURCE_PROFILE=gemini-2
# RAG_GPU_TARGET_PROFILE=cuda-qwen0.6b-1024
# RAG_LOCAL_EMBED_DEVICE=cuda
# RAG_CUDA_BATCH_SIZE=8

# Named embed profiles (see: uv run repo-rag embed profiles)
# RAG_EMBED_PROFILE=openai-large
# RAG_EMBED_PROFILE=cuda-qwen0.6b-1024

# Gemini (optional: rag-common[gemini])
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Legacy embedding backend: auto (OpenAI if key valid, else local), openai, local, or gemini
# RAG_EMBED_BACKEND=auto

# Optional overrides:
# REPO_RAG_EMBED_BACKEND=auto
# REPO_RAG_EMBED_MODEL=text-embedding-3-large
# REPO_RAG_EMBED_DIMS=3072
# RAG_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
# REPO_RAG_LOG=1
# REPO_RAG_LOG_LEVEL=INFO
# REPO_RAG_WORKERS=12
