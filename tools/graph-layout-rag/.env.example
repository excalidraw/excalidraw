OPENAI_API_KEY=sk-your-key-here

# Optional: CORE API for archive PDF fallbacks (https://core.ac.uk/services/api)
# CORE_API_KEY=

# --- Named embed profiles (recommended; see: uv run graph-layout-rag embed profiles) ---
# RAG_EMBED_PROFILE=mlx-qwen4b          # local MLX 4-bit Qwen3-4B @ 1024 dims
# RAG_EMBED_PROFILE=openai-large        # cloud text-embedding-3-large @ 1024 dims
# RAG_EMBED_PROFILE=gemini              # gemini-embedding-001 @ 768 dims (AI Studio key)
# RAG_EMBED_PROFILE=gemini-2            # gemini-embedding-2 @ 3072 dims (Vertex or AI Studio)
# GRAPH_RAG_EMBED_PROFILE=mlx-qwen4b    # tool-specific override of RAG_EMBED_PROFILE

# Gemini Embedding 2 via Vertex AI (requires rag-common[gemini])
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json  # optional; omit if using gcloud ADC

# Gemini via AI Studio (alternative to Vertex)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Legacy embedding backend (implicit "default" profile if RAG_EMBED_PROFILE unset) ---
# RAG_EMBED_BACKEND=auto|openai|local|gemini
# auto = OpenAI if OPENAI_API_KEY valid, else local Qwen3-0.6B

# --- Cloud ingest (fast one-time build, ~$5-7 full corpus on text-embedding-3-large) ---
# RAG_EMBED_BACKEND=openai
# RAG_OPENAI_EMBED_MODEL=text-embedding-3-large
# RAG_OPENAI_EMBED_DIMS=1024
# GRAPH_RAG_WORKERS=4

# --- Local ingest on Apple Silicon (MLX 4-bit Qwen3-4B, free, ~10-15+ active hours full corpus) ---
# RAG_EMBED_BACKEND=local
# RAG_LOCAL_EMBED_MODEL=Qwen/Qwen3-Embedding-4B
# RAG_LOCAL_EMBED_DIMS=1024
# RAG_LOCAL_EMBED_QUANT=4bit
# GRAPH_RAG_INGEST_DOC_BATCH=10
# GRAPH_RAG_INGEST_SCAN_LOG_EVERY=100
# RAG_MLX_ENCODE_CHUNK=32
# RAG_MLX_BATCH_SIZE=8
# MPS fallback (if RAG_LOCAL_EMBED_QUANT=off, Sentence Transformers on MPS):
# RAG_MPS_ENCODE_CHUNK=12
# RAG_MPS_BATCH_SIZE=4
# RAG_QWEN3_QUERY_INSTRUCT=Given a web search query, retrieve relevant passages that answer the query

# Lighter local: RAG_LOCAL_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B  RAG_LOCAL_EMBED_DIMS=1024  RAG_LOCAL_EMBED_QUANT=4bit
# Legacy fallback: RAG_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2  RAG_LOCAL_EMBED_DIMS=384

# Each RAG_EMBED_PROFILE gets its own index under data/indexes/{profile}/ (lancedb + ingest_state.json).
# Build multiple indexes for A/B testing: ingest with one profile, then another; query with --embed-profile.
# List built indexes: uv run graph-layout-rag embed indexes

# Ingest: resume with `uv run graph-layout-rag ingest -v` (no --force after interrupt).
# Logs: data/ingest.log. Prevent sleep: caffeinate -dims uv run graph-layout-rag ingest -v
# Do not run query during ingest on 24GB Mac (OOM). Query cost after build: ~$0 local, negligible OpenAI.
