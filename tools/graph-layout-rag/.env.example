OPENAI_API_KEY=sk-your-key-here

# OpenAlex free key. Singleton lookups are free; metered search/list work is capped locally
# to the daily free-dollar budget so this tool never intentionally consumes prepaid credit.
# OPENALEX_API_KEY=
# GRAPH_RAG_OPENALEX_CONCURRENCY=32
# GRAPH_RAG_OPENALEX_RPS=100
# GRAPH_RAG_OPENALEX_FREE_BUDGET_USD=1.0

# Semantic Scholar shared anonymous pool: burst, cool down on 429, then resume automatically.
# GRAPH_RAG_S2_CONCURRENCY=32
# GRAPH_RAG_S2_RPS=1000
# GRAPH_RAG_S2_COOLDOWN_SECONDS=300

# Optional: CORE API for archive PDF fallbacks (https://core.ac.uk/services/api)
# CORE_API_KEY=
# GRAPH_RAG_CORE_CONCURRENCY=2
# GRAPH_RAG_CORE_RPS=0.4166667  # personal key default: 25/min; unauthenticated default: 10/min

# --- Named embed profiles (recommended; see: uv run graph-layout-rag embed profiles) ---
# RAG_EMBED_PROFILE=mlx-qwen4b          # local MLX 4-bit Qwen3-4B @ 1024 dims
# RAG_EMBED_PROFILE=openai-large        # cloud text-embedding-3-large @ 1024 dims
# RAG_EMBED_PROFILE=gemini              # gemini-embedding-001 @ 768 dims (AI Studio key)
# RAG_EMBED_PROFILE=gemini-2-structure-v1 # stable gemini-embedding-2 @ 3072 dims (Gemini API access)
# GRAPH_RAG_EMBED_PROFILE=mlx-qwen4b    # tool-specific override of RAG_EMBED_PROFILE

# Gemini Embedding 2 via Vertex AI (requires rag-common[gemini])
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json  # optional; omit if using gcloud ADC
#
# Adaptive TPM pacing (avoids 429 backoff during ingest; tune after checking Vertex quotas)
# RAG_GEMINI_TOKENS_PER_MIN=2000000      # hard cap; default 2M (match your Vertex quota)
# RAG_GEMINI_RATE_HEADROOM=0.95          # target fraction of cap proactively
# RAG_GEMINI_MIN_INTERVAL_MS=5           # floor between embed_content calls (gemini-2)
# RAG_GEMINI_RATE_STATE_PATH=            # optional; default ~/.cache/rag-common/gemini_rate_state.json

# Gemini via AI Studio (alternative to Vertex)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- PDF extraction backend (default pymupdf; docling = local ML; gemini = vision-LLM) ---
# Reuses the Gemini auth above (Vertex or AI Studio). gemini makes ONE API call per page —
# use `ingest compare-extract --all --limit N` to A/B before committing; switching the
# ingest backend changes embedded/BM25 text and requires `ingest --force --rebuild`.
# GRAPH_RAG_PDF_BACKEND=gemini
# GRAPH_RAG_EXTRACT_WORKERS=4                    # Docling/PyMuPDF processes; 0 or 1 = serial
# GRAPH_RAG_DOCLING_OCR=0                       # 0 is faster for born-digital papers
# GRAPH_RAG_DOCLING_TABLES=1                    # preserve table structure
# GRAPH_RAG_DOCLING_TIMEOUT_S=600               # per-document conversion timeout
# GRAPH_RAG_DOCLING_DEVICE=auto                 # auto|cpu|cuda|mps|xpu
# GRAPH_RAG_DOCLING_THREADS=2                   # threads inside each Docling worker
# GRAPH_RAG_GEMINI_VISION_MODEL=gemini-3.5-flash # flash = fast/cheap OCR; gemini-3.x pro needs the -preview id
# GRAPH_RAG_GEMINI_VISION_LOCATION=global        # gemini-3.x is served from `global`, not us-central1
# GRAPH_RAG_GEMINI_VISION_DPI=200                # page render resolution
# GRAPH_RAG_GEMINI_VISION_MAX_PAGES=0            # 0 = all; cap pages/doc to bound A/B cost
# GRAPH_RAG_GEMINI_VISION_CONCURRENCY=8          # in-flight page calls (async pool); 1 = sequential
#   Hard-capped at 200 in code: this project bursts 400 concurrent clean, breaks at 700 (429s);
#   real ~6.8k-tok pages hit TPM before then, so 200 leaves headroom. Values above 200 are clamped.
# GRAPH_RAG_GEMINI_VISION_TIMEOUT_MS=120000      # per-request HTTP timeout (guards SDK socket stalls)
# GRAPH_RAG_GEMINI_VISION_MIN_INTERVAL_MS=0      # floor between page calls (only used when CONCURRENCY=1)
# GRAPH_RAG_GEMINI_VISION_COST_PER_MTOK=2.0      # only for the est. $/doc column in compare
# Pages render synchronously then transcribe via the async client (client.aio) bounded by a
# semaphore — we avoid ThreadPoolExecutor over the sync client (documented hangs: python-genai #1893).

# --- Legacy embedding backend (implicit "default" profile if RAG_EMBED_PROFILE unset) ---
# RAG_EMBED_BACKEND=auto|openai|local|gemini
# auto = OpenAI if OPENAI_API_KEY valid, else local Qwen3-0.6B

# --- Cloud ingest (fast one-time build, ~$5-7 full corpus on text-embedding-3-large) ---
# RAG_EMBED_BACKEND=openai
# RAG_OPENAI_EMBED_MODEL=text-embedding-3-large
# RAG_OPENAI_EMBED_DIMS=1024
# GRAPH_RAG_WORKERS=4

# --- Local ingest on Apple Silicon (MLX 4-bit Qwen3-4B, free, ~10-15+ active hours full corpus) ---
# RAG_EMBED_BACKEND=local
# RAG_LOCAL_EMBED_MODEL=Qwen/Qwen3-Embedding-4B
# RAG_LOCAL_EMBED_DIMS=1024
# RAG_LOCAL_EMBED_QUANT=4bit
# GRAPH_RAG_WORKERS=48
# GRAPH_RAG_BIB_RELEVANCE_WORKERS=24            # OpenAlex DOI relevance lookups
# GRAPH_RAG_BIB_RELEVANCE_CHECKPOINT_EVERY=200 # decisions saved per batch
# GRAPH_RAG_BIB_SCAN_WORKERS=8                  # local PDF extraction/cache population
# GRAPH_RAG_INGEST_DOC_BATCH=25
# GRAPH_RAG_EXTRACT_QUEUE_DOCS=50        # bounded extracted-document queue; default 2 x doc batch
# GRAPH_RAG_INGEST_SCAN_LOG_EVERY=100
# GRAPH_RAG_INGEST_PROGRESS_LOG_EVERY=25       # INFO progress/ETA after this many documents
# GRAPH_RAG_INGEST_PROGRESS_LOG_INTERVAL_S=30  # or after this many seconds, whichever comes first
# RAG_MLX_ENCODE_CHUNK=32
# RAG_MLX_BATCH_SIZE=8
# MPS fallback (if RAG_LOCAL_EMBED_QUANT=off, Sentence Transformers on MPS):
# RAG_MPS_ENCODE_CHUNK=12
# RAG_MPS_BATCH_SIZE=4
# RAG_QWEN3_QUERY_INSTRUCT=Given a web search query, retrieve relevant passages that answer the query

# Lighter local: RAG_LOCAL_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B  RAG_LOCAL_EMBED_DIMS=1024  RAG_LOCAL_EMBED_QUANT=4bit
# Legacy fallback: RAG_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2  RAG_LOCAL_EMBED_DIMS=384

# Each RAG_EMBED_PROFILE gets its own index under data/indexes/{profile}/ (lancedb + ingest_state.json).
# Build multiple indexes for A/B testing: ingest with one profile, then another; query with --embed-profile.
# List built indexes: uv run graph-layout-rag embed indexes

# Ingest: resume with `uv run graph-layout-rag ingest -v` (no --force after interrupt).
# Logs: data/ingest.log. Prevent sleep: caffeinate -dims uv run graph-layout-rag ingest -v
# Do not run query during ingest on 24GB Mac (OOM). Query cost after build: ~$0 local, negligible OpenAI.
# Retrieval benchmark safety for a 24 GB Apple Silicon machine.
RAG_RERANK_BATCH_SIZE=8
GRAPH_RAG_MAX_CLOUD_RANKING_UNITS=500

# --- Remote GPU box (Ubuntu + RTX 3060 Ti, SSH-only) ---
# Mac: dev/ingest/hybrid. Ubuntu: CUDA encode + Qdrant for SPLADE/ColBERT experiments.
# GRAPH_RAG_GPU_SSH=user@your-gpu-host
# GRAPH_RAG_GPU_REMOTE_ROOT=~/excalidraw-tf
# GRAPH_RAG_QDRANT_URL=http://127.0.0.1:6333          # on Ubuntu during index build
# GRAPH_RAG_ENCODE_DEVICE=auto                         # auto|cpu|cuda (cuda on GPU box)
# GRAPH_RAG_FASTEMBED_CUDA=1                             # legacy alias; prefer GRAPH_RAG_ENCODE_DEVICE=cuda
# GRAPH_RAG_FASTEMBED_PROVIDERS=CUDAExecutionProvider
# Mac sync: scripts/gpu_sync_to_remote.sh && scripts/gpu_sync_from_remote.sh
