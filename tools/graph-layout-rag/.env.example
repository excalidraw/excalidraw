OPENAI_API_KEY=sk-your-key-here

# Embedding backend: auto (OpenAI if key valid, else local MiniLM), openai, or local
# RAG_EMBED_BACKEND=auto

# Optional overrides (defaults: text-embedding-3-large, 3072 dims)
# GRAPH_RAG_EMBED_BACKEND=auto
# GRAPH_RAG_EMBED_MODEL=text-embedding-3-large
# GRAPH_RAG_EMBED_DIMS=3072
# GRAPH_RAG_WORKERS=2
# RAG_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
