{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "excalidraw-app/index.tsx",
    "packages/excalidraw/index.tsx",
    "packages/excalidraw/index-node.ts",
    "packages/excalidraw/**/*.test.{ts,tsx}",
    "packages/excalidraw/scripts/precomputeTerraformLayoutCache.vitest.ts",
    "packages/excalidraw/tests/**/*.{ts,tsx}",
    "packages/{common,element,math,utils}/src/index.ts",
    "packages/{common,element,math,utils}/**/*.test.{ts,tsx}",
    "functions/**/*.ts",
    "vitest.config.mts",
    "setupTests.ts",
    "setupVitestCanvasMock.ts",
    "scripts/build-node.js",
    "scripts/buildPackage.js",
    "scripts/buildBase.js",
    "scripts/buildDocs.js",
    "scripts/buildWasm.js",
    "scripts/release.js"
  ],
  "project": ["excalidraw-app/**/*.{ts,tsx,mjs}", "packages/{common,element,excalidraw,math,utils}/**/*.{ts,tsx,mjs}", "functions/**/*.ts", "scripts/**/*.{js,mjs}"],
  "ignore": [
    "packages/backend/**",
    "**/__snapshots__/**",
    "functions/generated/**",
    ".agents/**",
    "examples/**",
    "dev-docs/**",
    "packages/excalidraw/components/ButtonIconCycle.tsx",
    "packages/excalidraw/components/Paragraph.tsx",
    "packages/excalidraw/data/ai/types.ts",
    "packages/excalidraw/index-node.ts"
  ],
  "ignoreDependencies": [
    "@babel/preset-env",
    "@types/chai",
    "@types/jest",
    "@vitest/ui",
    "chai",
    "http-server",
    "nodemon",
    "pepjs",
    "rewire",
    "vitest-canvas-mock",
    "@excalidraw/eslint-config",
    "eslint-config-prettier",
    "eslint-config-react-app",
    "eslint-plugin-import",
    "eslint-plugin-prettier",
    "eslint-plugin-sonarjs",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser",
    "dependency-cruiser",
    "oxlint",
    "@sonar/scan",
    "lint-staged",
    "dotenv",
    "@braintree/sanitize-url",
    "@excalidraw/random-username",
    "cross-env",
    "es6-promise-pool",
    "fractional-indexing",
    "perfect-freehand",
    "pwacompat",
    "sass",
    "@excalidraw/laser-pointer",
    "browser-fs-access",
    "pako",
    "png-chunk-text",
    "png-chunks-encode",
    "png-chunks-extract",
    "@testing-library/jest-dom",
    "@types/resize-observer-browser",
    "autoprefixer",
    "esbuild",
    "esbuild-sass-plugin",
    "eslint-plugin-react",
    "fake-indexeddb",
    "fonteditor-core",
    "harfbuzzjs",
    "jest-diff",
    "wawoff2",
    "which"
  ],
  "ignoreIssues": {
    "**/*": ["exports", "types", "nsExports", "nsTypes", "enumMembers", "duplicates", "unlisted", "binaries"]
  },
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["terraform", "wrangler", "cross-env", "build", "start", "eslint"]
}
