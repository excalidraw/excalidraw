rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Clients and drawings - open read/write (protected by PIN gate in app)
    match /clients/{clientId} {
      allow read, write: if true;
    }
    match /clients/{clientId}/drawings/{drawingId} {
      allow read, write: if true;
    }
  }
}
