# Development Environment Configuration
# This file contains safe defaults for local development
# DO NOT use these values in production!
# For production, copy .env.example to .env.production and configure appropriately

NODE_ENV=development
PORT=3003

# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/excalidraw

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3001

# File Upload Configuration (4MB in bytes)
MAX_FILE_SIZE=4194304
